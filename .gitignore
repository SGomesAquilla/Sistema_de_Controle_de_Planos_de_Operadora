# ==========================================
# Compilação e Dependências (Modo Monorepo)
# ==========================================
# Sem a barra inicial (/), ignora em qualquer nível/microsserviço
node_modules/
dist/
build/

# ==========================================
# Logs e Relatórios
# ==========================================
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ==========================================
# Sistemas Operacionais
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Testes e Cobertura
# ==========================================
# Removida a barra inicial para ignorar testes de todos os microsserviços
coverage/
.nyc_output/

# ==========================================
# IDEs, Editores e Ferramentas
# ==========================================
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode (Mantém configurações compartilhadas do time)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ==========================================
# Variáveis de Ambiente (Segurança)
# ==========================================
# Ignora arquivos .env na raiz ou dentro de qualquer microsserviço
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==========================================
# Pastas Temporárias e Runtime
# ==========================================
.temp/
.tmp/
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ==========================================
# Prisma ORM
# ==========================================
# Ignora artefatos gerados pelo Prisma em qualquer microsserviço
generated/prisma/