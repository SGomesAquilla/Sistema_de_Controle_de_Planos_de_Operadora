{
  "info": {
    "_postman_id": "sistema-controle-planos-fase-2",
    "name": "Sistema de Controle de Planos - Fase 1 e 2",
    "description": "Coleção completa via API Gateway. Todos os endpoints são acessados através de http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "ServicoGestao",
      "item": [
        {
          "name": "Listar todos os clientes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/clientes",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "clientes"]
            },
            "description": "Lista todos os clientes cadastrados"
          },
          "response": []
        },
        {
          "name": "Listar todos os planos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/planos",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "planos"]
            },
            "description": "Lista todos os planos cadastrados"
          },
          "response": []
        },
        {
          "name": "Criar assinatura",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codCli\": 1,\n  \"codPlano\": 1,\n  \"custoFinal\": 39.90,\n  \"descricao\": \"Desconto fidelidade 20% aplicado\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturas",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturas"]
            },
            "description": "Cria uma nova assinatura. Ao criar, publica o evento 'assinatura.criada' no RabbitMQ"
          },
          "response": []
        },
        {
          "name": "Atualizar custo mensal do plano",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"custoMensal\": 59.90\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/gestao/planos/1",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "planos", "1"]
            },
            "description": "Atualiza o custo mensal do plano informado"
          },
          "response": []
        },
        {
          "name": "Listar assinaturas por tipo - TODOS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturas/TODOS",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturas", "TODOS"]
            },
            "description": "Retorna todas as assinaturas, independente do status"
          },
          "response": []
        },
        {
          "name": "Listar assinaturas por tipo - ATIVOS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturas/ATIVOS",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturas", "ATIVOS"]
            },
            "description": "Retorna apenas as assinaturas com status ATIVO"
          },
          "response": []
        },
        {
          "name": "Listar assinaturas por tipo - CANCELADOS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturas/CANCELADOS",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturas", "CANCELADOS"]
            },
            "description": "Retorna apenas as assinaturas com status CANCELADO"
          },
          "response": []
        },
        {
          "name": "Buscar assinatura por código",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturas/codigo/1",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturas", "codigo", "1"]
            },
            "description": "Retorna uma única assinatura pelo código. Endpoint criado na Fase 2 para suporte ao ServicoPlanosAtivos"
          },
          "response": []
        },
        {
          "name": "Listar assinaturas por cliente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturascliente/1",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturascliente", "1"]
            },
            "description": "Retorna todas as assinaturas do cliente informado"
          },
          "response": []
        },
        {
          "name": "Listar assinaturas por plano",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/gestao/assinaturasplano/1",
              "host": ["{{gateway_url}}"],
              "path": ["gestao", "assinaturasplano", "1"]
            },
            "description": "Retorna todas as assinaturas do plano informado"
          },
          "response": []
        }
      ]
    },
    {
      "name": "ServicoFaturamento",
      "item": [
        {
          "name": "Registrar pagamento",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dia\": 21,\n  \"mes\": 6,\n  \"ano\": 2026,\n  \"codAss\": 1,\n  \"valorPago\": 71.90\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/registrarpagamento",
              "host": ["{{gateway_url}}"],
              "path": ["registrarpagamento"]
            },
            "description": "Registra um pagamento. Publica dois eventos assíncronos no RabbitMQ: PagamentoPlanoServicoGestao e PagamentoPlanoServicoPlanosAtivos. Resposta: nenhum corpo (void)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "ServicoPlanosAtivos",
      "item": [
        {
          "name": "Verificar se assinatura está ativa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/planosativos/1",
              "host": ["{{gateway_url}}"],
              "path": ["planosativos", "1"]
            },
            "description": "Retorna true ou false indicando se a assinatura está ativa. Consulta cache Redis primeiro; em caso de miss, consulta o ServicoGestao e repovoa o cache"
          },
          "response": []
        }
      ]
    }
  ]
}